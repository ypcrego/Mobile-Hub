<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pomodoro_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_swamp">

    <FrameLayout
        android:id="@+id/frogContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_voltar_hub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; Voltar"
        android:background="@android:color/transparent"
        android:fontFamily="@font/pixel_sproutlands"
        android:minWidth="@dimen/zero_dp"
        android:minHeight="@dimen/zero_dp"
        android:padding="@dimen/normal_dp"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_preferences"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Configurações" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/normal_dp"
        android:textSize="64sp"
        android:fontFamily="@font/pixel_sproutlands"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintTop_toBottomOf="@id/btn_voltar_hub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnToggleTimer"
        android:layout_width="140dp"
        android:layout_height="60dp"
        android:layout_marginBottom="32dp"
        android:text="@string/iniciar"
        android:fontFamily="@font/pixel_sproutlands"
        android:textColor="#5D4037"
        android:textSize="16sp"
        android:background="@drawable/button"
        app:backgroundTint="@null"
        android:stateListAnimator="@null"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnResetTimer" />

    <Button
        android:id="@+id/btnResetTimer"
        android:layout_width="140dp"
        android:layout_height="60dp"
        android:layout_marginBottom="32dp"
        android:text="@string/reset"
        android:fontFamily="@font/pixel_sproutlands"
        android:textColor="#5D4037"
        android:textSize="16sp"
        android:background="@drawable/button"
        app:backgroundTint="@null"
        android:stateListAnimator="@null"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnToggleTimer"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>