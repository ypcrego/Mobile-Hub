<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MobileHub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.MobileHub" parent="Base.Theme.MobileHub" />

    <style name="Base.Theme.Calculadora" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cardview_dark_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/material_on_surface_disabled</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimary</item>
    </style>

    <style name="Theme.Calculadora" parent="Base.Theme.Calculadora" />

    <style name="PetCalcButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">@dimen/button_margin</item>

        <item name="backgroundTint">@color/btn_bg</item>
        <item name="android:textColor">@color/btn_text</item>
        <item name="android:fontFamily">@font/pixel_sproutlands</item>
        <item name="autoSizeTextType">uniform</item>
        <item name="autoSizeMinTextSize">12sp</item>
        <item name="autoSizeMaxTextSize">36sp</item>
        <item name="autoSizeStepGranularity">2sp</item>
    </style>

    <style name="IconButton" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">@dimen/button_margin</item>

        <item name="android:background">@android:color/transparent</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="CalculatorDisplay">
        <item name="android:gravity">bottom|end</item>
        <item name="android:textColor">@color/display_text</item>
        <item name="android:background">@drawable/bg_display_rounded</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:fontFamily">@font/pixel_sproutlands</item>
    </style>
</resources>

<!-- Base application theme. -->

