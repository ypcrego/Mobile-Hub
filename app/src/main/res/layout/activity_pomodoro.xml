<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pomodoro_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_swamp">

    <Button
        android:id="@+id/btn_voltar_hub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; Voltar"
        android:background="@android:color/transparent"
        android:fontFamily="@font/pixel_sproutlands"
        android:minWidth="@dimen/zero_dp"
        android:minHeight="@dimen/zero_dp"
        android:padding="@dimen/normal_dp"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <include
        layout="@layout/layout_theme_toggle"
        android:id="@+id/btnTema"
        android:layout_width="@dimen/extra_large_dp"
        android:layout_height="@dimen/extra_large_dp"
        android:layout_marginTop="@dimen/small_dp"
        android:layout_marginEnd="@dimen/small_dp"
        android:elevation="@dimen/extra_small_dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/normal_dp"
        android:textSize="64sp"
        android:fontFamily="@font/pixel_sproutlands"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintTop_toBottomOf="@id/btn_voltar_hub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/frogContainer"
        android:layout_width="@dimen/zero_dp"
        android:layout_height="@dimen/zero_dp"
        android:layout_margin="@dimen/normal_dp"
        app:layout_constraintTop_toBottomOf="@id/tvTimer"
        app:layout_constraintBottom_toTopOf="@id/btnToggleTimer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnToggleTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/large_dp"
        android:text="@string/iniciar"
        android:fontFamily="@font/pixel_sproutlands"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnResetTimer" />

    <Button
        android:id="@+id/btnResetTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/large_dp"
        android:text="@string/reset"
        android:fontFamily="@font/pixel_sproutlands"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnToggleTimer"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>